import bpy
import math

scene = bpy.context.scene

# ------------SETTINGS---------------
start = 0 # START ANIM FRAME
end = 7 # END ANIM FRAME
obj = bpy.data.objects["nodes_0"]

output_path = "C:/renders/pikmin/"


# south
obj.rotation_euler.z = math.radians(0)

for f in range(start, end + 1):
    scene.frame_set(f)
    bpy.context.scene.render.filepath = f"{output_path}south_{f:03d}.png"
    bpy.ops.render.render(write_still=True)
    
