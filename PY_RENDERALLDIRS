# PUT THIS SCRIPT IN BLENDER
import bpy
import math

scene = bpy.context.scene

# ------------SETTINGS---------------
start = 0
end = 7
obj = bpy.data.objects["nodes_0"]

output_path = "C:/renders/pikmin/midres/"


